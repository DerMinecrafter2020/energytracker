# ===== APPLICATION =====
DB_TYPE=redis
NODE_ENV=production
PORT=3001
CORS_ORIGIN=http://localhost:3001

# ===== REDIS =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== AUTH / SECURITY =====
SESSION_SECRET=bitte-aendern-langer-zufaelliger-wert
SESSION_TTL_MS=604800000
PASSWORD_SALT=et-caffeine-salt-2024
# Optionaler Fallback. Empfohlen: Verschluesselungskennwort im Admin-Panel setzen.
SECRET_ENCRYPTION_KEY=

# Demo-Zugaenge sind serverseitig und werden nicht ins Frontend gebaut.
ADMIN_EMAIL=admin@energytracker.de
ADMIN_PASSWORD=Admin@2024!
USER_EMAIL=user@energytracker.de
USER_PASSWORD=User@2024!

# ===== WEBAUTHN / PASSKEYS =====
WEBAUTHN_RP_NAME=Koffein-Tracker
WEBAUTHN_ORIGIN=http://localhost:3001
WEBAUTHN_RP_ID=localhost

# ===== FRONTEND (Vite) =====
# API Backend URL (Frontend braucht das)
VITE_API_BASE_URL=http://localhost:3001
VITE_ADMIN_EMAIL=admin@energytracker.de
VITE_USER_EMAIL=user@energytracker.de

# ===== OPTIONAL: S3 BACKUPS =====
# AWS S3 oder kompatible Anbieter wie MinIO, Hetzner, Wasabi, Backblaze.
S3_BUCKET=
S3_REGION=eu-central-1
S3_ENDPOINT=
S3_PREFIX=koffein-tracker/backups
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
