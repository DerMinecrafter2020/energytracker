# ===== .env.local für den PRODUCTION Server in Docker =====
# Kopiere diese Datei zu /root/energytracker/.env.local auf dem Server
# und trage deine sicheren Werte ein.

# ===== FILE DATABASE =====
# Einfache lokale JSON-Datei, kein separater DB-Server notwendig.
DB_FILE=/app/data/database.json

# ===== APPLICATION =====
DB_TYPE=file-json
NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://deine-domain.com

# ===== AUTH / SECURITY =====
# Ändere diese Werte für Produktion!
SESSION_SECRET=dein-langer-zufaelliger-session-secret
SESSION_TTL_MS=604800000
PASSWORD_SALT=dein-eindeutiges-passwort-salt

# Demo-Zugaenge nur serverseitig setzen oder im Admin-Panel deaktivieren.
ADMIN_EMAIL=admin@deine-domain.com
ADMIN_PASSWORD=ein-sehr-sicheres-admin-passwort
USER_EMAIL=user@deine-domain.com
USER_PASSWORD=ein-sehr-sicheres-user-passwort

# ===== OPTIONAL: FRONTEND URLS =====
VITE_API_BASE_URL=https://deine-domain.com
VITE_ADMIN_EMAIL=admin@deine-domain.com
VITE_USER_EMAIL=user@deine-domain.com
