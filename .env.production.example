# ===== .env.local für den PRODUCTION Server in Docker =====
# Kopiere diese Datei zu /root/energytracker/.env.local auf dem Server
# und trage deine sicheren Werte ein.

# ===== FILE DATABASE =====
# Einfache lokale JSON-Datei, kein separater DB-Server notwendig.
DB_FILE=/app/data/database.json

# ===== APPLICATION =====
DB_TYPE=file-json
NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://deine-domain.com

# ===== ADMIN SECURITY =====
# Ändere diese Werte für Produktion!
ADMIN_SECRET=dein-eindeutiger-admin-secret
PASSWORD_SALT=dein-eindeutiges-passwort-salt

# ===== OPTIONAL: FRONTEND URLS =====
VITE_API_BASE_URL=https://deine-domain.com
VITE_ADMIN_SECRET=dein-eindeutiger-admin-secret
